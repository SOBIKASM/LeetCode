#1.recursion
class Solution:
    def myPow(self, x: float, n: int) -> float:
        if n<0:
            return self.myPow(1.0/x,-n)
        return self.power(x,n)
    def power(self,x:float,n:int)->float:
        if n==0:
            return 1.0
        if n==1:
            return x
        if n%2==0:
            return self.myPow(x*x,n//2)
        return x*self.myPow(x,n-1)        

#2.Built-in function
import math 
class Solution:
    def myPow(self, x: float, n: int) -> float:
        res = math.pow(x,n)
        return res
        
