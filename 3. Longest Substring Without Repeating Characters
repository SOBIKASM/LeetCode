class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        n = len(s)
        if n == 0:
            return 0
        longest = 1
        count = 1
        for i in range(n):
            for j in range(i+1,n):
                if s[j] in s[i:j]:
                    longest = max(longest,count)
                    break
                else : 
                    count += 1
            
            longest = max(longest,count)
            count = 1
        return longest
